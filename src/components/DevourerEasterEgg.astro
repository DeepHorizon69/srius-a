---
import '../styles/devourer-easter-egg.css';

const publicBase = import.meta.env.BASE_URL.replace(/\/$/, '');
const dogScriptSrc = `${publicBase}/DOG/dog.js`;
const dogAudioSrc = `${publicBase}/DOG/1dog.mp3`;
---

<div class="dog-event" id="dog-event" aria-hidden="true">
  <canvas class="dog-event__canvas" id="dog-canvas"></canvas>
  <p
    class="dog-event__dialog"
    id="dog-dialog"
    data-message="You are no god...but I shall feast upon your essence regardless!"
    role="status"
    aria-live="polite"
  ></p>
  <button type="button" class="dog-event__skip" id="dog-skip">Skip event</button>
  <audio id="dog-audio" src={dogAudioSrc} preload="auto"></audio>
</div>
<script is:inline src={dogScriptSrc}></script>
<script>
  import '../scripts/devourer-easter-egg';
</script>
